# PORT: The network port where our Node.js server will run locally.
# Usually 3000 or 5000 is used for development.
PORT=3000

# MONGO_URI: The connection string for MongoDB database.
# For local databases, it is usually mongodb://127.0.0.1:27017/database_name
MONGO_URI=mongodb://127.0.0.1:27017/sales_dashboard

# SESSION_SECRET: A secret random text used by express-session to sign 
# the session cookies. This prevents users from tampering with their session ID.
SESSION_SECRET=your_super_secret_session_key_here
